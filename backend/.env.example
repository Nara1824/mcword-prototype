# ─────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO - MacWorld Ecuador
# ─────────────────────────────────────────────────────────────
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Rellena cada valor con tus datos reales
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# ── SERVIDOR ─────────────────────────────────────────────────
# Puerto donde corre el servidor localmente
# En Render este valor se ignora (Render asigna el suyo)
PORT=3000

# ── BASE DE DATOS ─────────────────────────────────────────────
# URI de conexión a MongoDB Atlas
# Cómo obtenerla:
#   1. Crea cuenta en https://cloud.mongodb.com
#   2. Crea cluster gratuito (M0)
#   3. Database Access → Add user (pon usuario y contraseña)
#   4. Network Access → Add IP → 0.0.0.0/0 (permite todos)
#   5. Connect → Drivers → copia la URI
#   6. Reemplaza <password> con tu contraseña real
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/macworld?retryWrites=true&w=majority

# ── JWT (SEGURIDAD) ───────────────────────────────────────────
# Clave secreta para firmar tokens de autenticación
# IMPORTANTE: Usa una cadena larga y aleatoria (mínimo 32 chars)
# Genera una en: https://generate-secret.vercel.app/32
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_secreta_123456

# Cuánto tiempo dura el token de login (7d = 7 días)
JWT_EXPIRES_IN=7d

# ── WHATSAPP ──────────────────────────────────────────────────
# Número de WhatsApp donde llegan los pedidos
# Formato: código de país + número SIN espacios SIN el +
# Ejemplo Ecuador: 593991234567
# ↓ CAMBIA ESTE NÚMERO POR EL TUYO ↓
WHATSAPP_NUMBER=593991234567

# ── ADMIN (credenciales del primer admin) ─────────────────────
# Se usan SOLO al correr: npm run create-admin
# Después de crear el admin, puedes cambiar la contraseña desde el panel
ADMIN_EMAIL=admin@macworld.ec
ADMIN_PASSWORD=CambiarEsto123!
ADMIN_NAME=Administrador

# ── FRONTEND ──────────────────────────────────────────────────
# URL del frontend (para CORS)
# Local: http://localhost:3000
# Producción: https://tu-app.onrender.com
FRONTEND_URL=http://localhost:3000
